# ===========================================
# SpiderMind - Coze API 配置
# ===========================================
# 【重要】请将此文件的 Token 替换为你的真实 Token
# 如何获取 Token：
#   1. 访问 https://www.coze.cn 并登录
#   2. 右上角头像 → 个人中心
#   3. 左侧菜单 → 访问令牌 → 新建令牌
#   4. 过期时间选"无过期时间"（永久有效）
#   5. 权限勾选 chat
#   6. 点击确认，复制生成的 Token
#   7. 粘贴到下方 COZE_API_TOKEN= 后面
# ===========================================

# Coze API Token（必须配置）
# 格式：pat_xxx（个人令牌）
COZE_API_TOKEN=在这里填入你的Token

# Coze Bot ID（已预设，一般无需修改）
COZE_BOT_ID=7623014360998461482
